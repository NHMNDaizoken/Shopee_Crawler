{
  "manifest_version": 3,
  "name": "Shopee Review Scraper",
  "version": "1.1.3",
  "description": "Extract product reviews from Shopee. v1.1.3: 2-phase + skip star=0 từ item_rating_summary.rating_count để tiết kiệm thời gian.",
  "permissions": ["activeTab", "scripting", "downloads", "storage", "tabs", "alarms"],
  "host_permissions": ["*://*.shopee.vn/*", "*://*.shopee.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shopee Review Scraper"
  },
  "content_scripts": [
    {
      "matches": ["*://*.shopee.vn/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
