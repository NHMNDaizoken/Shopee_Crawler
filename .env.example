ENV=dev
PROXY_URL=none

# --- Browser / profile ---
# SHOPEE_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# SHOPEE_PROFILE_DIR=D:\Ki2_nam3\shopee_eda\shopee_profile_chrome
SHOPEE_CHROME_PORT=9222
SHOPEE_SHOP_FINDER_PORT=9234

# --- Main pipeline ---
SHOPEE_AUTO_FIND_SHOPS=0
# SHOPEE_KEYWORDS=ao thun nam|giay sneaker nam
SHOPEE_MAX_SHOP_PAGES=1
SHOPEE_PRODUCT_LIMIT=

# --- Review crawl subset / retry ---
SHOPEE_REVIEW_ONLY_PENDING=1
SHOPEE_REVIEW_SKIP_SAMPLED=1
SHOPEE_REVIEW_REFRESH_EVERY=40
SHOPEE_REVIEWS_PER_STAR=5
# SHOPEE_REVIEW_ITEMIDS=123456789,987654321
SHOPEE_REVIEW_START_INDEX=0

